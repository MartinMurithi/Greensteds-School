# ──────────────────────────────────────────────────────────────────────────────
# Environment Variables — Greensteds International School
#
# 1. Copy this file:  cp .env.example .env.local
# 2. Fill in the values below
# 3. Never commit .env.local to git
# ──────────────────────────────────────────────────────────────────────────────

# Site URL (no trailing slash)
# Local:      http://localhost:3000
# Production: https://greensteds-redesign.vercel.app
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Resend API Key
# Get this from: https://resend.com/api-keys
# The free tier allows 100 emails/day — more than enough for a school demo
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Email address that receives contact form submissions
# Recommend using the school admissions email in production
CONTACT_TO_EMAIL=email@example.com